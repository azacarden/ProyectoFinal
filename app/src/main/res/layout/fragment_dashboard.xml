<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡Hola! ¿Qué quieres hacer hoy?"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="24dp" />

        <androidx.gridlayout.widget.GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:columnCount="2"
            app:alignmentMode="alignMargins"
            app:columnOrderPreserved="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMedicacion"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_agenda" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mis Pastillas" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAdd"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_input_add" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nueva Toma" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHistorial"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Historial" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlarmas"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_lock_idle_alarm" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alarmas" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCuidadores"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_share" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cuidadores" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPerfil"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="0dp"
                android:layout_height="160dp"
                app:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@android:drawable/ic_menu_manage" app:tint="?attr/colorPrimary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mi Perfil" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.gridlayout.widget.GridLayout>
    </LinearLayout>
</ScrollView>