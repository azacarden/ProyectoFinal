<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Material3.CardView.Elevated"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvMotivoItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Revisión Semestral"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvMedicoItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Médico: Dr. García"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvEspecialidadItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Especialidad: Cardiología"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvHospitalItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hospital/Centro: Carlos Haya"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvNotasCitaItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notas: Ir en ayunas"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/calendar"
                app:tint="?attr/colorSecondary" />

            <TextView
                android:id="@+id/tvFechaHoraItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="15/06/2026 a las 10:00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorSecondary" />

            <ImageButton
                android:id="@+id/btnBorrarCita"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/delete"
                app:tint="#D32F2F" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>